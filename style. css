body{
background:#0f172a;
font-family:Arial;
color:white;
text-align:center;
}

header{
padding:30px;
}

button{
width:250px;
padding:15px;
margin:10px;
font-size:20px;
border:none;
border-radius:15px;
background:#2196f3;
color:white;
cursor:pointer;
}

button:hover{
background:#1565c0;
}
.hero{
    margin-top:40px;
}

.hero input{
    width:80%;
    max-width:500px;
    padding:15px;
    border-radius:10px;
    border:none;
    font-size:18px;
}

.hero button{
    margin:10px;
}