function image() {
    let prompt = document.getElementById("prompt").value;

    if(prompt==""){
        alert("Please enter a prompt.");
        return;
    }

    document.getElementById("result").innerHTML =
    "<h3>Generating...</h3><p>Prompt: " + prompt + "</p>";
}
function video() {
    let prompt = document.getElementById("prompt").value;

    if(prompt==""){
        alert("Please enter a prompt.");
        return;
    }

    alert("Generating AI Video for:\n\n" + prompt);
}

